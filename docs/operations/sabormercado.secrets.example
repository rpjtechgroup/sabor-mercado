# Deploy automático (GitHub Actions): cadastre estes valores em
# Settings → Secrets and variables → Actions → Repository secrets
#
# Deploy manual (scripts/deploy.ps1): copie para /home/ubuntu/deploy/sabormercado.secrets na VM

# Infra (já usados antes da feature 009)
SABOR_DB_PASS=
SABOR_JWT_KEY=

# Feature 009 — e-mail + Google Sign-In
SABOR_SMTP_PASSWORD=
SABOR_GOOGLE_CLIENT_ID=
