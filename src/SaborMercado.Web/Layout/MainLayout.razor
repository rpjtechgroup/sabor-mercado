@inherits LayoutComponentBase
@implements IDisposable
@inject UiPreferencesState UiPrefs
@inject IPreferencesStore Preferences

<div class="app-shell @(UiPrefs.ShowIconLabels ? "app-shell--labels" : "app-shell--icons-only")">
    <header class="app-topbar" aria-label="Barra superior">
        <IconLabelToggle />
    </header>

    <ToastHost />
    <ShoppingToastNotifier />
    <main class="app-content">
        @Body
    </main>

    <AppBottomNav />
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await UiPrefs.InitializeAsync(Preferences);
        UiPrefs.Changed += OnUiPrefsChanged;
    }

    private void OnUiPrefsChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => UiPrefs.Changed -= OnUiPrefsChanged;
}
