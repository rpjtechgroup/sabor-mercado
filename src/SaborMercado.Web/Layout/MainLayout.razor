@inherits LayoutComponentBase
@implements IDisposable
@inject UiPreferencesState UiPrefs
@inject IPreferencesStore Preferences

<div class="@_shellClass">
    <header class="app-topbar" aria-label="Barra superior">
        <IconButton Icon="@(UiPrefs.ShowIconLabels ? AppIcons.IconsOnly : AppIcons.IconsWithText)"
                    Label="@(UiPrefs.ShowIconLabels ? "Mostrar só ícones" : "Mostrar ícones com texto")"
                    CssClass="btn btn-outline btn-icon app-topbar-toggle"
                    OnClick="ToggleIconLabelsAsync" />
    </header>

    <ToastHost />
    <ShoppingToastNotifier />
    <main class="app-content">
        @Body
    </main>

    <nav class="bottom-nav" aria-label="Navegação principal">
        <IconNavLink Href="" Icon="@AppIcons.Shopping" Label="Compra" CssClass="bottom-nav-link" Match="NavLinkMatch.All" />
        <IconNavLink Href="catalogo" Icon="@AppIcons.Catalog" Label="Catálogo" CssClass="bottom-nav-link" />
        <IconNavLink Href="configuracoes" Icon="@AppIcons.Settings" Label="Ajustes" CssClass="bottom-nav-link" />
    </nav>
</div>

@code {
    private string _shellClass = "app-shell app-shell--labels";

    protected override async Task OnInitializedAsync()
    {
        await UiPrefs.InitializeAsync(Preferences);
        UpdateShellClass();
        UiPrefs.Changed += OnUiPrefsChanged;
    }

    private async Task ToggleIconLabelsAsync()
    {
        await UiPrefs.SetShowIconLabelsAsync(Preferences, !UiPrefs.ShowIconLabels);
    }

    private void OnUiPrefsChanged()
    {
        UpdateShellClass();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateShellClass() =>
        _shellClass = UiPrefs.ShowIconLabels
            ? "app-shell app-shell--labels"
            : "app-shell app-shell--icons-only";

    public void Dispose() => UiPrefs.Changed -= OnUiPrefsChanged;
}
