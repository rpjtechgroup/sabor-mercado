@inherits LayoutComponentBase
@implements IDisposable
@inject UiPreferencesState UiPrefs
@inject IPreferencesStore Preferences

<div class="app-shell @(UiPrefs.ShowIconLabels ? "app-shell--labels" : "app-shell--icons-only")">
    <header class="app-topbar" aria-label="Barra superior">
        <IconButton Icon="@(UiPrefs.ShowIconLabels ? AppIcons.IconsOnly : AppIcons.IconsWithText)"
                    Label="@(UiPrefs.ShowIconLabels ? "Mostrar só ícones" : "Mostrar ícones com texto")"
                    CssClass="btn btn-outline btn-icon app-topbar-toggle"
                    OnClick="ToggleIconLabelsAsync" />
    </header>

    <ToastHost />
    <ShoppingToastNotifier />
    <main class="app-content">
        @Body
    </main>

    <AppBottomNav />
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await UiPrefs.InitializeAsync(Preferences);
        UiPrefs.Changed += OnUiPrefsChanged;
    }

    private async Task ToggleIconLabelsAsync()
    {
        await UiPrefs.SetShowIconLabelsAsync(Preferences, !UiPrefs.ShowIconLabels);
        StateHasChanged();
    }

    private void OnUiPrefsChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => UiPrefs.Changed -= OnUiPrefsChanged;
}
