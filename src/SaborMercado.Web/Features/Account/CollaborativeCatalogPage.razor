@page "/catalogo-colaborativo"
@using SaborMercado.Web.Contracts.SharedCatalog
@implements IDisposable
@inject AccountService Account
@inject CollaborativeCatalogService Catalog

<PageTitle>Sabor Mercado — Catálogo colaborativo</PageTitle>

<div class="collab-catalog-page">
    <PageLayout Icon="@AppIcons.Catalog"
                Title="Catálogo colaborativo"
                Subtitle="Preços compartilhados anonimamente por outros usuários.">
    @if (!_loaded)
    {
        <p class="muted">Carregando…</p>
    }
    else if (!Account.IsLoggedIn)
    {
        <p class="muted"><IconInlineLink Href="conta" Icon="@AppIcons.Login" Label="Entre na sua conta" /> para acessar.</p>
    }
    else
    {
        <div class="card">
            <label for="collab-query">Buscar produto</label>
            <input id="collab-query" class="input" @bind="_query" @bind:event="oninput" placeholder="ex.: arroz" />
            <IconButton Icon="@AppIcons.Search" Label="Buscar" CssClass="btn btn-primary btn-block btn-icon" Disabled="@(_searching || string.IsNullOrWhiteSpace(_query))" OnClick="SearchAsync" />
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="text-danger" role="alert">@_error</p>
        }

        @if (_results.Count == 0 && _searched)
        {
            <p class="muted">Nenhum produto encontrado.</p>
        }
        else
        {
            @foreach (var item in _results)
            {
                <div class="card price-row">
                    <strong>@item.NormalizedName</strong>
                    @if (!string.IsNullOrWhiteSpace(item.Brand))
                    {
                        <span class="muted"> · @item.Brand</span>
                    }
                    @if (item.LastPrice is { } price)
                    {
                        <p>@MoneyFormat.Format(price) @if (item.LastMarketName is not null) { <span class="muted">· @item.LastMarketName</span> }</p>
                    }
                    else
                    {
                        <p class="muted">Sem preço recente</p>
                    }
                    <IconLink Href="@($"catalogo-colaborativo/{item.ProductId}")" Icon="@AppIcons.Catalog" Label="Ver observações" CssClass="btn btn-secondary btn-block btn-icon icon-link" />
                    <IconLink Href="@($"comparar-mercados/{item.ProductId}")" Icon="@AppIcons.Compare" Label="Comparar mercados" CssClass="btn btn-outline btn-block btn-icon icon-link" />
                </div>
            }
        }
    }

    <p class="muted"><IconInlineLink Href="conta" Icon="@AppIcons.Back" Label="Minha conta" /></p>
    </PageLayout>
</div>

@code {
    private bool _loaded;
    private bool _searching;
    private bool _searched;
    private string _query = string.Empty;
    private string? _error;
    private List<SharedProductSummaryDto> _results = [];

    protected override async Task OnInitializedAsync()
    {
        Account.StateChanged += OnStateChanged;
        await Account.InitializeAsync();
        _loaded = true;
    }

    private async Task SearchAsync()
    {
        _searching = true;
        _error = null;
        _searched = true;
        try
        {
            var response = await Catalog.SearchAsync(_query);
            _results = response.Items.ToList();
        }
        catch (CollaborativeCatalogException ex)
        {
            _error = ex.Message;
            _results = [];
        }
        finally
        {
            _searching = false;
        }
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Account.StateChanged -= OnStateChanged;
}
