@page "/catalogo-colaborativo"
@implements IDisposable
@inject AccountService Account
@inject CollaborativeCatalogService Catalog

<PageTitle>Sabor Mercado — Catálogo colaborativo</PageTitle>

<div class="collab-catalog-page">
    <header class="session-header">
        <h1>Catálogo colaborativo</h1>
        <p class="muted">Preços compartilhados anonimamente por outros usuários.</p>
    </header>

    @if (!_loaded)
    {
        <p class="muted">Carregando…</p>
    }
    else if (!Account.IsLoggedIn)
    {
        <p class="muted"><a href="conta">Entre na sua conta</a> para acessar.</p>
    }
    else if (!Account.HasUnlock(PremiumFeatureCodes.CollaborativePriceHistory))
    {
        <div class="card">
            <p>Desbloqueie o histórico colaborativo em <a href="conta">Minha conta</a> (10 créditos).</p>
        </div>
    }
    else
    {
        <div class="card">
            <label for="collab-query">Buscar produto</label>
            <input id="collab-query" class="input" @bind="_query" @bind:event="oninput" placeholder="ex.: arroz" />
            <button type="button" class="btn btn-primary btn-block" disabled="@(_searching || string.IsNullOrWhiteSpace(_query))" @onclick="SearchAsync">
                Buscar
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="text-danger" role="alert">@_error</p>
        }

        @if (_results.Count == 0 && _searched)
        {
            <p class="muted">Nenhum produto encontrado.</p>
        }
        else
        {
            @foreach (var item in _results)
            {
                <div class="card price-row">
                    <strong>@item.NormalizedName</strong>
                    @if (!string.IsNullOrWhiteSpace(item.Brand))
                    {
                        <span class="muted"> · @item.Brand</span>
                    }
                    @if (item.LastPrice is { } price)
                    {
                        <p>@MoneyFormat.Format(price) @if (item.LastMarketName is not null) { <span class="muted">· @item.LastMarketName</span> }</p>
                    }
                    else
                    {
                        <p class="muted">Sem preço recente</p>
                    }
                    @if (Account.HasUnlock(PremiumFeatureCodes.MarketComparison))
                    {
                        <a class="btn btn-outline btn-block" href="comparar-mercados/@item.ProductId">Comparar mercados</a>
                    }
                </div>
            }
        }
    }

    <p class="muted"><a href="conta">‹ Minha conta</a></p>
</div>

@code {
    private bool _loaded;
    private bool _searching;
    private bool _searched;
    private string _query = string.Empty;
    private string? _error;
    private List<Contracts.SharedCatalog.SharedProductSummaryDto> _results = [];

    protected override async Task OnInitializedAsync()
    {
        Account.StateChanged += OnStateChanged;
        await Account.InitializeAsync();
        _loaded = true;
    }

    private async Task SearchAsync()
    {
        _searching = true;
        _error = null;
        try
        {
            var response = await Catalog.SearchAsync(_query.Trim());
            _results = response.Items.ToList();
            _searched = true;
        }
        catch (CollaborativeCatalogException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _searching = false;
        }
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Account.StateChanged -= OnStateChanged;
}
