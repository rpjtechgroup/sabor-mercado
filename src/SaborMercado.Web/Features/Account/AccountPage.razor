@page "/conta"
@using SaborMercado.Web.Contracts.Community
@implements IDisposable
@using SaborMercado.Web.Features.Gamification.Components
@inject AccountService Account
@inject CommunityService Community
@inject GamificationMetricsService GamificationMetrics
@inject NavigationManager Navigation

<PageTitle>Sabor Mercado — Minha conta</PageTitle>

<PageLayout Icon="@AppIcons.Account"
            Title="Minha conta">
    @if (!_loaded)
    {
        <p class="muted">Carregando…</p>
    }
    else if (!Account.IsLoggedIn)
    {
        <SettingsSection Id="auth-heading" Icon="@(_registerMode ? AppIcons.New : AppIcons.Login)" Title="@(_registerMode ? "Criar conta" : "Entrar")">
            <p class="muted">
                Conta leve (e-mail e senha). Seus dados de compra permanecem no dispositivo.
            </p>

            <div class="form-field">
                <label for="account-email">E-mail</label>
                <input id="account-email" class="input" type="email" autocomplete="username" @bind="_email" />
            </div>
            <div class="form-field">
                <label for="account-password">Senha</label>
                <input id="account-password" class="input" type="password" autocomplete="@(_registerMode ? "new-password" : "current-password")" @bind="_password" />
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="text-danger" role="alert">@_error</p>
            }

            <IconButton Icon="@(_registerMode ? AppIcons.New : AppIcons.Login)"
                        Label="@(_registerMode ? "Criar conta" : "Entrar")"
                        CssClass="btn btn-primary btn-block btn-icon"
                        Disabled="@_busy"
                        OnClick="SubmitAuthAsync" />
            <p class="auth-divider muted">ou</p>
            <GoogleSignInButton OnError="OnGoogleError" />
            @if (!string.IsNullOrEmpty(_googleError))
            {
                <p class="text-danger google-auth-error" role="alert">@_googleError</p>
            }
            <IconButton Icon="@(_registerMode ? AppIcons.Login : AppIcons.New)"
                        Label="@(_registerMode ? "Já tenho conta" : "Criar conta gratuita")"
                        CssClass="btn btn-outline btn-block btn-icon"
                        OnClick="ToggleMode" />
        </SettingsSection>
    }
    else
    {
        @if (Account.PendingShareCount > 0)
        {
            <p class="muted" role="status">@Account.PendingShareCount compartilhamento(s) aguardando envio.</p>
            <IconButton Icon="@AppIcons.Refresh" Label="Tentar enviar agora" CssClass="btn btn-secondary btn-block btn-icon" OnClick="FlushPendingAsync" />
        }
        <IconLink Href="catalogo-colaborativo" Icon="@AppIcons.Catalog" Label="Catálogo colaborativo" CssClass="btn btn-secondary btn-block btn-icon icon-link" />
        <IconLink Href="estatisticas" Icon="@AppIcons.Chart" Label="Estatísticas de gastos" CssClass="btn btn-secondary btn-block btn-icon icon-link" />
        <IconLink Href="rankings" Icon="@AppIcons.Trophy" Label="Rankings" CssClass="btn btn-secondary btn-block btn-icon icon-link" />
        <IconButton Icon="@AppIcons.Logout" Label="Sair" CssClass="btn btn-outline btn-block btn-icon" OnClick="LogoutAsync" />

        @if (GamificationMetrics.Current is { } metrics)
        {
            <div class="metrics-grid account-section">
                <div class="metric-card"><span class="metric-value">@metrics.TotalProductsRegistered</span><span class="metric-label">Produtos</span></div>
                <div class="metric-card"><span class="metric-value">@metrics.TotalStoresRegistered</span><span class="metric-label">Comércios</span></div>
                <div class="metric-card"><span class="metric-value">@metrics.TotalPurchasesCompleted</span><span class="metric-label">Compras</span></div>
                <div class="metric-card"><span class="metric-value">@metrics.CurrentLoginStreakDays</span><span class="metric-label">Dias seguidos</span></div>
            </div>
        }

        <p class="muted account-section">@_unlockedCount de @_totalCount conquistas desbloqueadas.</p>
        <div class="achievement-grid">
            @foreach (var badge in _achievementViews)
            {
                var unlocked = _unlockedCodes.Contains(badge.Code);
                var unlockedAt = _achievements.FirstOrDefault(a => a.Code == badge.Code)?.UnlockedAt;
                <AchievementBadge Title="@badge.Title"
                                  Description="@badge.Description"
                                  IsUnlocked="@unlocked"
                                  UnlockedAt="@unlockedAt"
                                  CurrentProgress="@badge.CurrentProgress"
                                  TargetProgress="@badge.TargetProgress" />
            }
        </div>

        <SettingsSection Id="danger-heading" Icon="@AppIcons.Warning" Title="Zona de perigo">
            <p class="muted">Exclui sua conta. Compartilhamentos já anonimizados permanecem no catálogo colaborativo.</p>
            @if (_confirmingDelete)
            {
                <IconButton Icon="@AppIcons.Warning" Label="Confirmar exclusão da conta" CssClass="btn btn-danger btn-block btn-icon" Disabled="@_busy" OnClick="DeleteAccountAsync" />
            }
            else
            {
                <IconButton Icon="@AppIcons.Remove" Label="Excluir conta" CssClass="btn btn-danger btn-block btn-icon" OnClick="AskDeleteAccount" />
            }
        </SettingsSection>
    }

    <p class="muted"><IconInlineLink Href="configuracoes" Icon="@AppIcons.Back" Label="Voltar aos ajustes" /></p>
</PageLayout>

@code {
    private bool _loaded;
    private bool _registerMode;
    private bool _busy;
    private bool _confirmingDelete;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string? _error;
    private string? _googleError;
    private List<AchievementDto> _achievements = [];
    private List<AchievementProgressView> _achievementViews = [];
    private HashSet<string> _unlockedCodes = new(StringComparer.Ordinal);
    private int _unlockedCount;
    private int _totalCount;

    protected override async Task OnInitializedAsync()
    {
        Account.StateChanged += OnStateChanged;
        GamificationMetrics.StateChanged += OnStateChanged;
        await Account.InitializeAsync();
        await GamificationMetrics.InitializeAsync();
        await LoadAchievementsAsync();
        _loaded = true;
    }

    private async Task LoadAchievementsAsync()
    {
        _achievementViews = GamificationMetrics.BuildLocalAchievementProgress().ToList();
        _totalCount = _achievementViews.Count;

        if (!Account.IsLoggedIn)
        {
            _achievements = [];
            _unlockedCodes = [];
            _unlockedCount = 0;
            return;
        }

        try
        {
            var response = await Community.ListAchievementsAsync();
            _achievements = response.Items.ToList();
            _unlockedCodes = _achievements.Select(a => a.Code).ToHashSet(StringComparer.Ordinal);
            _unlockedCount = _achievements.Count;
        }
        catch (CommunityException)
        {
            _achievements = [];
            _unlockedCodes = [];
            _unlockedCount = 0;
        }
    }

    private void ToggleMode()
    {
        _registerMode = !_registerMode;
        _error = null;
        _googleError = null;
    }

    private void OnGoogleError(string message)
    {
        _googleError = message;
        _error = null;
    }

    private void AskDeleteAccount() => _confirmingDelete = true;

    private async Task SubmitAuthAsync()
    {
        _busy = true;
        _error = null;
        _googleError = null;
        try
        {
            if (_registerMode)
            {
                await Account.RegisterAsync(_email.Trim(), _password);
            }
            else
            {
                await Account.LoginAsync(_email.Trim(), _password);
            }

            _password = string.Empty;
            await LoadAchievementsAsync();
        }
        catch (AccountException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task FlushPendingAsync()
    {
        _busy = true;
        await Account.FlushPendingSharesAsync();
        _busy = false;
    }

    private async Task LogoutAsync()
    {
        await Account.LogoutAsync();
        _error = null;
        _confirmingDelete = false;
        await LoadAchievementsAsync();
    }

    private async Task DeleteAccountAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            await Account.DeleteAccountAsync();
            _confirmingDelete = false;
            await LoadAchievementsAsync();
        }
        catch (AccountException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void OnStateChanged() => InvokeAsync(async () =>
    {
        await LoadAchievementsAsync();
        StateHasChanged();
    });

    public void Dispose()
    {
        Account.StateChanged -= OnStateChanged;
        GamificationMetrics.StateChanged -= OnStateChanged;
    }
}
