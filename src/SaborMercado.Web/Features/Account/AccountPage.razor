@page "/conta"
@implements IDisposable
@inject AccountService Account
@inject CommunityService Community
@inject NavigationManager Navigation

<PageTitle>Sabor Mercado — Minha conta</PageTitle>

<div class="account-page">
    <header class="session-header">
        <PageIcon Icon="@AppIcons.Account" Title="Minha conta" />
        <p class="muted">
            Compartilhe preços anonimizados para ganhar créditos e desbloquear recursos premium.
            O fluxo principal continua gratuito e offline.
        </p>
    </header>

    @if (!_loaded)
    {
        <p class="muted">Carregando…</p>
    }
    else if (!Account.IsLoggedIn)
    {
        <section class="card settings-section" aria-labelledby="auth-heading">
            <SectionIcon Id="auth-heading" Icon="@(_registerMode ? AppIcons.New : AppIcons.Login)" Title="@(_registerMode ? "Criar conta" : "Entrar")" />
            <p class="muted">
                Conta leve (e-mail e senha). Seus dados de compra permanecem no dispositivo.
            </p>

            <div class="form-field">
                <label for="account-email">E-mail</label>
                <input id="account-email" class="input" type="email" autocomplete="username" @bind="_email" />
            </div>
            <div class="form-field">
                <label for="account-password">Senha</label>
                <input id="account-password" class="input" type="password" autocomplete="@(_registerMode ? "new-password" : "current-password")" @bind="_password" />
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="text-danger" role="alert">@_error</p>
            }

            <IconButton Icon="@(_registerMode ? AppIcons.New : AppIcons.Login)"
                        Label="@(_registerMode ? "Criar conta" : "Entrar")"
                        CssClass="btn btn-primary btn-block btn-icon"
                        Disabled="@_busy"
                        OnClick="SubmitAuthAsync" />
            <IconButton Icon="@(_registerMode ? AppIcons.Login : AppIcons.New)"
                        Label="@(_registerMode ? "Já tenho conta" : "Criar conta gratuita")"
                        CssClass="btn btn-outline btn-block btn-icon"
                        OnClick="ToggleMode" />
        </section>
    }
    else
    {
        <section class="card settings-section" aria-labelledby="credits-heading">
            <SectionIcon Id="credits-heading" Icon="@AppIcons.Trophy" Title="Créditos" />
            <p class="totals-value">@Account.CreditBalance crédito@(Account.CreditBalance == 1 ? string.Empty : "s")</p>
            <p class="muted">Logado como @Account.Email</p>
            @if (Account.PendingShareCount > 0)
            {
                <p class="muted" role="status">@Account.PendingShareCount compartilhamento(s) aguardando envio.</p>
                <IconButton Icon="@AppIcons.Refresh" Label="Tentar enviar agora" CssClass="btn btn-secondary btn-block btn-icon" OnClick="FlushPendingAsync" />
            }
            @if (Account.HasUnlock(PremiumFeatureCodes.CollaborativePriceHistory))
            {
                <IconLink Href="catalogo-colaborativo" Icon="@AppIcons.Catalog" Label="Ver catálogo colaborativo" CssClass="btn btn-secondary btn-block btn-icon icon-link" />
            }
            @if (Account.HasUnlock(PremiumFeatureCodes.AdvancedStats))
            {
                <IconLink Href="estatisticas" Icon="@AppIcons.Chart" Label="Estatísticas avançadas" CssClass="btn btn-secondary btn-block btn-icon icon-link" />
            }
            @if (Account.HasUnlock(PremiumFeatureCodes.SmartLists))
            {
                <IconLink Href="listas-inteligentes" Icon="@AppIcons.List" Label="Listas inteligentes" CssClass="btn btn-secondary btn-block btn-icon icon-link" />
            }
            <IconButton Icon="@AppIcons.Logout" Label="Sair" CssClass="btn btn-outline btn-block btn-icon" OnClick="LogoutAsync" />
        </section>

        <section class="card settings-section" aria-labelledby="achievements-heading">
            <SectionIcon Id="achievements-heading" Icon="@AppIcons.Trophy" Title="Conquistas" />
            @if (_achievements.Count == 0)
            {
                <p class="muted">Contribua com preços e vote em observações para desbloquear conquistas.</p>
            }
            else
            {
                <div class="achievement-grid">
                    @foreach (var badge in _achievements)
                    {
                        <div class="achievement-badge" title="@badge.Description">
                            <span class="achievement-badge-title">@badge.Title</span>
                            <span class="muted achievement-badge-date">@badge.UnlockedAt.ToLocalTime().ToString("dd/MM/yyyy")</span>
                        </div>
                    }
                </div>
            }
        </section>

        <section class="card settings-section" aria-labelledby="unlocks-heading">
            <SectionIcon Id="unlocks-heading" Icon="@AppIcons.Unlock" Title="Desbloqueios premium" />
            @foreach (var offer in UnlockOffers.All)
            {
                var active = Account.HasUnlock(offer.Code);
                <div class="unlock-row">
                    <div>
                        <strong>@offer.Label</strong>
                        <p class="muted">@offer.Cost créditos · @offer.DurationLabel</p>
                    </div>
                    @if (active)
                    {
                        <span class="text-ok">Ativo</span>
                    }
                    else
                    {
                        <IconButton Icon="@AppIcons.Unlock"
                                    Label="Desbloquear"
                                    CssClass="btn btn-secondary btn-icon"
                                    Disabled="@_busy"
                                    OnClick="@(() => UnlockAsync(offer.Code))" />
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(_unlockMessage))
            {
                <p class="success-text" role="status">@_unlockMessage</p>
            }
            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="text-danger" role="alert">@_error</p>
            }
        </section>

        <section class="card settings-section" aria-labelledby="danger-heading">
            <SectionIcon Id="danger-heading" Icon="@AppIcons.Warning" Title="Zona de perigo" />
            <p class="muted">Exclui sua conta. Compartilhamentos já anonimizados permanecem no catálogo colaborativo.</p>
            @if (_confirmingDelete)
            {
                <IconButton Icon="@AppIcons.Warning" Label="Confirmar exclusão da conta" CssClass="btn btn-danger btn-block btn-icon" Disabled="@_busy" OnClick="DeleteAccountAsync" />
            }
            else
            {
                <IconButton Icon="@AppIcons.Remove" Label="Excluir conta" CssClass="btn btn-danger btn-block btn-icon" OnClick="AskDeleteAccount" />
            }
        </section>
    }

    <p class="muted"><IconInlineLink Href="configuracoes" Icon="@AppIcons.Back" Label="Voltar aos ajustes" /></p>
</div>

@code {
    private bool _loaded;
    private bool _registerMode;
    private bool _busy;
    private bool _confirmingDelete;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string? _error;
    private string? _unlockMessage;
    private List<AchievementDto> _achievements = [];

    protected override async Task OnInitializedAsync()
    {
        Account.StateChanged += OnStateChanged;
        await Account.InitializeAsync();
        await LoadAchievementsAsync();
        _loaded = true;
    }

    private async Task LoadAchievementsAsync()
    {
        if (!Account.IsLoggedIn)
        {
            _achievements = [];
            return;
        }

        try
        {
            var response = await Community.ListAchievementsAsync();
            _achievements = response.Items.ToList();
        }
        catch (CommunityException)
        {
            _achievements = [];
        }
    }

    private void ToggleMode()
    {
        _registerMode = !_registerMode;
        _error = null;
    }

    private void AskDeleteAccount() => _confirmingDelete = true;

    private async Task SubmitAuthAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            if (_registerMode)
            {
                await Account.RegisterAsync(_email.Trim(), _password);
            }
            else
            {
                await Account.LoginAsync(_email.Trim(), _password);
            }

            _password = string.Empty;
            await LoadAchievementsAsync();
        }
        catch (AccountException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task UnlockAsync(string featureCode)
    {
        _busy = true;
        _error = null;
        _unlockMessage = null;
        try
        {
            await Account.UnlockAsync(featureCode);
            _unlockMessage = "Funcionalidade desbloqueada.";
        }
        catch (AccountException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task FlushPendingAsync()
    {
        _busy = true;
        await Account.FlushPendingSharesAsync();
        _busy = false;
    }

    private async Task LogoutAsync()
    {
        await Account.LogoutAsync();
        _unlockMessage = null;
        _error = null;
        _confirmingDelete = false;
    }

    private async Task DeleteAccountAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            await Account.DeleteAccountAsync();
            _confirmingDelete = false;
        }
        catch (AccountException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void OnStateChanged() => InvokeAsync(async () =>
    {
        await LoadAchievementsAsync();
        StateHasChanged();
    });

    public void Dispose() => Account.StateChanged -= OnStateChanged;
}
