@page "/configuracoes"
@inject IPreferencesStore Preferences
@inject GeminiVoiceUtteranceClient GeminiVoice
@inject NavigationManager Navigation

<PageTitle>Sabor Mercado — Configurações</PageTitle>

<PageLayout Icon="@AppIcons.Settings" Title="Configurações">
    <SettingsSection Id="account-heading" Icon="@AppIcons.Account" Title="Conta e conquistas">
        <p class="muted">
            Crie uma conta para compartilhar preços anonimizados, desbloquear conquistas
            e participar dos rankings da comunidade.
        </p>
        <IconLink Href="conta" Icon="@AppIcons.Account" Label="Minha conta" CssClass="btn btn-secondary btn-block btn-icon icon-link" />
    </SettingsSection>

    <SettingsSection Id="gemini-heading" Icon="@AppIcons.Photo" Title="Gemini (foto e voz)">
        <p class="muted">
            Para usar leitura por foto e interpretação de fala, informe sua chave da API Gemini (free tier).
            A chave fica <strong>somente neste dispositivo</strong> (localStorage)
            e não é enviada ao nosso servidor.
        </p>
        <p class="muted">
            Obtenha uma chave gratuita em
            <IconInlineLink Href="https://aistudio.google.com/apikey"
                            Icon="@AppIcons.Link"
                            Label="Google AI Studio"
                            Target="_blank"
                            Rel="noopener noreferrer" />.
        </p>

        <div class="form-field">
            <label for="gemini-key">Chave da API Gemini</label>
            <input id="gemini-key"
                   class="input"
                   type="password"
                   autocomplete="off"
                   @bind="_apiKey"
                   placeholder="AIza…" />
        </div>

        @if (!string.IsNullOrEmpty(_message))
        {
            <p class="success-text" role="status">@_message</p>
        }

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="text-over" role="alert">@_error</p>
        }

        <IconButton Icon="@AppIcons.Save" Label="Salvar chave" CssClass="btn btn-primary btn-block btn-icon" OnClick="SaveAsync" />

        <IconButton Icon="@AppIcons.Confirm"
                    Label="@(_testing ? "Testando…" : "Testar chave")"
                    CssClass="btn btn-secondary btn-block btn-icon"
                    Disabled="@(_testing || string.IsNullOrWhiteSpace(_apiKey))"
                    OnClick="TestKeyAsync" />

        @if (_hasStoredKey)
        {
            <IconButton Icon="@AppIcons.Remove" Label="Remover chave salva" CssClass="btn btn-outline btn-block btn-icon" OnClick="RemoveAsync" />
        }
    </SettingsSection>
</PageLayout>

@code {
    private string _apiKey = string.Empty;
    private bool _hasStoredKey;
    private bool _testing;
    private string? _message;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var stored = await Preferences.GetGeminiApiKeyAsync();
        _hasStoredKey = !string.IsNullOrWhiteSpace(stored);
        if (_hasStoredKey)
        {
            _apiKey = stored!;
        }
    }

    private async Task SaveAsync()
    {
        await Preferences.SetGeminiApiKeyAsync(string.IsNullOrWhiteSpace(_apiKey) ? null : _apiKey);
        _hasStoredKey = !string.IsNullOrWhiteSpace(_apiKey);
        _message = "Chave salva neste dispositivo.";
        _error = null;
    }

    private async Task TestKeyAsync()
    {
        _testing = true;
        _message = null;
        _error = null;

        try
        {
            await GeminiVoice.ValidateApiKeyAsync(_apiKey.Trim());
            _message = "Chave válida. Conexão com o Gemini OK.";
        }
        catch (HttpRequestException ex)
        {
            _error = DescribeHttpError(ex);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _testing = false;
        }
    }

    private static string DescribeHttpError(HttpRequestException ex)
    {
        var message = ex.Message;
        if (message.Contains("API_KEY_INVALID", StringComparison.OrdinalIgnoreCase) ||
            message.Contains("API key not valid", StringComparison.OrdinalIgnoreCase))
        {
            return "Chave inválida. Gere uma nova no Google AI Studio.";
        }

        return string.IsNullOrWhiteSpace(message) ? "Falha ao contactar o Gemini." : message;
    }

    private async Task RemoveAsync()
    {
        await Preferences.SetGeminiApiKeyAsync(null);
        _apiKey = string.Empty;
        _hasStoredKey = false;
        _message = "Chave removida.";
        _error = null;
    }
}
