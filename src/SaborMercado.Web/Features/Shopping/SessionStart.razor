
<div class="card">
    <PageIcon Icon="@AppIcons.New" Title="Nova compra" />

    <div class="field">
        <span class="field-label">Tipo de compra</span>
        <div class="session-kind-toggle" role="radiogroup" aria-label="Tipo de compra">
            <IconButton Icon="@AppIcons.Calendar"
                        Label="Compra mensal"
                        CssClass="@($"btn btn-icon {(_kind == SessionKind.Monthly ? "btn-primary" : "btn-outline")}")"
                        AdditionalAttributes="@MonthlyRadioAttrs"
                        OnClick="@(() => SetKind(SessionKind.Monthly))" />
            <IconButton Icon="@AppIcons.Shopping"
                        Label="Compra esporádica"
                        CssClass="@($"btn btn-icon {(_kind == SessionKind.Sporadic ? "btn-primary" : "btn-outline")}")"
                        AdditionalAttributes="@SporadicRadioAttrs"
                        OnClick="@(() => SetKind(SessionKind.Sporadic))" />
        </div>
    </div>

    @if (_kind == SessionKind.Monthly)
    {
        <p class="muted">
            O carrinho será pré-preenchido com sua lista mensal e os últimos preços conhecidos.
            Orçamento e alertas de meta não se aplicam.
        </p>
        <IconLink Href="compra-mensal" Icon="@AppIcons.Edit" Label="Editar lista mensal" CssClass="btn btn-outline btn-block btn-icon icon-link" />
    }
    else
    {
        <p class="muted">Defina uma meta para receber alertas durante a compra. Os dois campos são opcionais.</p>

        <div class="field">
            <label for="budget">Quanto pretende gastar?</label>
            <MoneyInput Id="budget" @bind-Value="_budget" Placeholder="ex.: 300,00" />
        </div>
    }

    <StorePicker Label="Comércio" Placeholder="Opcional" @bind-SelectedStoreId="_storeId" />

    <IconButton Icon="@(_kind == SessionKind.Monthly ? AppIcons.Calendar : AppIcons.Play)"
                Label="@(_kind == SessionKind.Monthly ? "Iniciar compra mensal" : "Começar compra")"
                CssClass="btn btn-primary btn-block btn-icon"
                OnClick="StartAsync" />
</div>

@code {
    private SessionKind _kind = SessionKind.Sporadic;
    private decimal? _budget;
    private Guid _storeId;
    private bool _suggestionApplied;

    private Dictionary<string, object> MonthlyRadioAttrs => new()
    {
        ["role"] = "radio",
        ["aria-checked"] = _kind == SessionKind.Monthly,
    };

    private Dictionary<string, object> SporadicRadioAttrs => new()
    {
        ["role"] = "radio",
        ["aria-checked"] = _kind == SessionKind.Sporadic,
    };

    [Parameter]
    public decimal? SuggestedBudget { get; set; }

    [Parameter]
    public EventCallback<SessionStartRequest> OnStart { get; set; }

    protected override void OnParametersSet()
    {
        if (!_suggestionApplied && SuggestedBudget is { } suggested && _kind == SessionKind.Sporadic)
        {
            _budget = suggested;
            _suggestionApplied = true;
        }
    }

    private void SetKind(SessionKind kind) => _kind = kind;

    private Task StartAsync() =>
        OnStart.InvokeAsync(new SessionStartRequest(
            _kind,
            _kind == SessionKind.Sporadic ? _budget : null,
            _storeId == Guid.Empty ? null : _storeId));
}
