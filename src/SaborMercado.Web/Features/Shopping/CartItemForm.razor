@using SaborMercado.Web.Domain.Catalog
@using SaborMercado.Web.Features.Catalog
@using SaborMercado.Web.Features.Voice

<div class="card">
    <div class="card-header-row">
        <SectionIcon Icon="@(IsEdit ? AppIcons.Edit : AppIcons.New)" Title="@(IsEdit ? "Editar item" : "Adicionar item")" />
    </div>

    <VoiceLiteralPanel Target="VoiceExtractionTarget.CartItem"
                       Placeholder="Fale ou digite o item (ex.: óleo de soja Liza novecentos ml nove e noventa dois pacotes)"
                       OnExtracted="ApplyVoiceExtractionAsync" />

    <div class="field">
        <label for="item-name">Produto *</label>
        <ProductAutocomplete InputId="item-name"
                             Name="@Model.Name"
                             NameChanged="OnNameChangedAsync"
                             OnProductSelected="ApplyProductAsync" />
    </div>

    <div class="field">
        <label for="item-brand">Marca</label>
        <input id="item-brand" class="input" @bind="Model.Brand" placeholder="opcional" />
    </div>

    <div class="field-row">
        <div class="field">
            <label for="item-qty-value">Peso/volume</label>
            <input id="item-qty-value" class="input" type="number" step="any" min="0" @bind="Model.QuantityValue" placeholder="ex.: 900" />
        </div>
        <div class="field">
            <label for="item-qty-unit">Unidade</label>
            <select id="item-qty-unit" class="input" @bind="Model.QuantityUnit">
                <option value="">—</option>
                @foreach (var unit in Enum.GetValues<QuantityUnit>())
                {
                    <option value="@unit">@unit.Label()</option>
                }
            </select>
        </div>
    </div>

    <div class="field-row">
        <div class="field">
            <label for="item-price">Preço unitário (R$) *</label>
            <MoneyInput Id="item-price" @bind-Value="Model.UnitPrice" Placeholder="ex.: 8,99" />
        </div>
        <div class="field">
            <label for="item-quantity">Quantidade *</label>
            <input id="item-quantity" class="input" type="number" min="1" @bind="Model.Quantity" />
        </div>
    </div>

    @if (_error is not null)
    {
        <p class="text-over" role="alert">@_error</p>
    }

    <div class="field-row">
        <IconButton Icon="@AppIcons.Cancel" Label="Cancelar" CssClass="btn btn-outline btn-block btn-icon" OnClick="CancelAsync" />
        <IconButton Icon="@AppIcons.Save" Label="Salvar" CssClass="btn btn-primary btn-block btn-icon" OnClick="SaveAsync" />
    </div>
</div>

@code {
    private string? _error;

    [Inject]
    public CatalogService Catalog { get; set; } = default!;

    [Parameter]
    public CartItemFormModel Model { get; set; } = new();

    [Parameter]
    public bool IsEdit { get; set; }

    [Parameter]
    public EventCallback<CartItemFormModel> OnSave { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private Task OnNameChangedAsync(string name)
    {
        Model.Name = name;
        return Task.CompletedTask;
    }

    private async Task ApplyProductAsync(Product product)
    {
        Model.Name = product.Name;
        Model.Brand = product.Brand;
        Model.QuantityValue = product.QuantityValue;
        Model.QuantityUnit = product.QuantityUnit;

        var lastPrice = await Catalog.GetLastKnownPriceAsync(product.Id);
        if (lastPrice is not null)
        {
            Model.UnitPrice = lastPrice.Price;
        }
    }

    private Task ApplyVoiceExtractionAsync(VoiceFieldExtractionResult result)
    {
        VoiceParsedFieldsApplicator.ApplyToCartItemForm(result.Fields, Model);
        return Task.CompletedTask;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(Model.Name))
        {
            _error = "Informe o nome do produto.";
            return;
        }

        if (Model.UnitPrice is null or < 0m)
        {
            _error = "Informe um preço válido (use vírgula para centavos).";
            return;
        }

        if (Model.Quantity < 1)
        {
            _error = "Quantidade deve ser pelo menos 1.";
            return;
        }

        _error = null;
        await OnSave.InvokeAsync(Model);
    }

    private Task CancelAsync() => OnCancel.InvokeAsync();
}
