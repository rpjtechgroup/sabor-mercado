@page "/historico"
@page "/historico/{SessionId:guid}"
@implements IDisposable

<PageTitle>Sabor Mercado — Comparador</PageTitle>

<PageLayout Icon="@AppIcons.Compare"
            Title="Comparador de compras"
            Subtitle="Últimos 3 meses · melhor e pior preço por produto">
@if (!_loaded)
{
    <p class="muted">Carregando…</p>
}
else
{
    <ProductPriceComparisonGrid Rows="@_rows"
                                ColumnOrder="@_columnOrder"
                                OnColumnOrderChanged="OnColumnOrderChangedAsync" />
}
</PageLayout>

@code {
    private bool _loaded;
    private List<ProductComparisonRow> _rows = [];
    private List<ComparatorColumnId> _columnOrder = ComparatorColumnOrder.DefaultOrder.ToList();

    [Parameter]
    public Guid? SessionId { get; set; }

    [Inject]
    public ProductPriceComparisonService Comparison { get; set; } = default!;

    [Inject]
    public IPreferencesStore Preferences { get; set; } = default!;

    [Inject]
    public NavigationManager Navigation { get; set; } = default!;

    protected override async Task OnParametersSetAsync()
    {
        if (SessionId is not null)
        {
            Navigation.NavigateTo("historico", replace: true);
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _rows = (await Comparison.GetComparisonRowsAsync()).ToList();
        _columnOrder = (await Preferences.GetComparatorColumnOrderAsync()).ToList();
        _loaded = true;
    }

    private async Task OnColumnOrderChangedAsync(IReadOnlyList<ComparatorColumnId> order)
    {
        _columnOrder = order.ToList();
        await Preferences.SetComparatorColumnOrderAsync(_columnOrder);
    }

    public void Dispose() { }
}
