@page "/"
@implements IDisposable

<PageTitle>Sabor Mercado — Compra</PageTitle>

@if (!_loaded)
{
    <p class="muted">Carregando…</p>
}
else if (Shopping.CurrentSession is null)
{
    @if (_showSummary && Shopping.LastFinishedSession is { } finished)
    {
        <PageLayout Icon="@AppIcons.Party" Title="Compra finalizada">
            <div class="card session-summary">
                @if (finished.MarketName is not null)
                {
                    <p class="muted">@finished.MarketName</p>
                }
                <IconButton Icon="@AppIcons.New" Label="Nova compra" CssClass="btn btn-primary btn-block btn-icon" OnClick="StartNew" />
                <IconLink Href="historico" Icon="@AppIcons.History" Label="Ver histórico desta compra" CssClass="btn btn-outline btn-block btn-icon icon-link history-link" />
            </div>
        </PageLayout>
    }
    else
    {
        <PageLayout Icon="@AppIcons.New" Title="Nova compra">
            <SessionStart SuggestedBudget="@Shopping.SuggestedBudget"
                          ReminderCount="@_reminderCount"
                          OnStart="StartSessionAsync" />
            <IconLink Href="lembretes"
                      Icon="@AppIcons.Reminder"
                      Label="@ReminderLinkLabel"
                      CssClass="btn btn-outline btn-block btn-icon icon-link" />
            <IconLink Href="historico" Icon="@AppIcons.History" Label="Histórico de compras" CssClass="btn btn-outline btn-block btn-icon icon-link history-link" />
        </PageLayout>
    }
}
else
{
    <PageLayout Icon="@AppIcons.Shopping" Title="@(Shopping.CurrentSession.MarketName ?? "Compra em andamento")">
        <StorePicker Label="Comércio desta compra"
                     SelectedStoreId="_sessionStoreId"
                     SelectedStoreIdChanged="OnSessionStoreChangedAsync"
                     AutoSelectSingleStore="false" />
        @if (Shopping.CurrentSession.Kind == SessionKind.Sporadic)
        {
            <BudgetBar Total="@Shopping.Total" Budget="@Shopping.CurrentSession.BudgetAmount" />
        }

        @if (Shopping.CurrentSession.Kind == SessionKind.Monthly || Shopping.CurrentSession.BudgetAmount is null)
        {
            <div class="card totals-row">
                <span class="muted">Total do carrinho</span>
                <span class="totals-value">@MoneyFormat.Format(Shopping.Total)</span>
            </div>
        }

        @if (_itemForm is not null)
        {
            <CartItemForm Model="@_itemForm"
                          IsEdit="@(_editingItemId is not null)"
                          OnSave="SaveItemAsync"
                          OnCancel="CloseItemForm" />
        }
        else
        {
            <IconLink Href="foto" Icon="@AppIcons.Photo" Label="Foto da etiqueta" CssClass="btn btn-primary btn-block btn-icon icon-link" />
            <IconButton Icon="@AppIcons.Manual" Label="Digitar manualmente" CssClass="btn btn-secondary btn-block btn-icon" OnClick="OpenAddForm" />
        }

        @if (Shopping.Items.Count == 0 && _itemForm is null)
        {
            <EmptyState Icon="🧺" Message="Carrinho vazio. Adicione o primeiro item para acompanhar o gasto." />
        }
        else
        {
            <section class="cart-list" aria-label="Itens do carrinho">
                @foreach (var item in Shopping.Items)
                {
                    <CartItemRow @key="item.Id"
                                 Item="@item"
                                 OnIncrement="@(delta => IncrementAsync(item.Id, delta))"
                                 OnSetQuantity="@(quantity => SetQuantityAsync(item.Id, quantity))"
                                 OnEdit="@(() => OpenEditForm(item))"
                                 OnRemove="@(() => RemoveAsync(item.Id))" />
                }
            </section>
        }

        <div class="session-actions">
            <IconButton Icon="@AppIcons.Finish" Label="Encerrar compra" CssClass="btn btn-primary btn-block btn-icon" OnClick="FinishAsync" />
            @if (_confirmingAbandon)
            {
                <IconButton Icon="@AppIcons.Warning" Label="Confirmar abandono (itens serão descartados)" CssClass="btn btn-danger btn-block btn-icon" OnClick="AbandonAsync" />
            }
            else
            {
                <IconButton Icon="@AppIcons.Abandon" Label="Abandonar compra" CssClass="btn btn-outline btn-block btn-icon" OnClick="AskAbandon" />
            }
        </div>
    </PageLayout>
}
