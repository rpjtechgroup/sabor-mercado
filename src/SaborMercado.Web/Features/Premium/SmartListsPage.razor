@page "/listas-inteligentes"
@inject SmartListService SmartLists

<PageTitle>Sabor Mercado — Listas inteligentes</PageTitle>

<PageLayout Icon="@AppIcons.List" Title="Listas inteligentes" Subtitle="Sugestões baseadas no seu histórico de compras local.">
    @if (!_loaded)
    {
        <p class="muted">Carregando…</p>
    }
    else if (_items.Count == 0)
    {
        <p class="muted">Finalize algumas compras para gerar sugestões.</p>
    }
    else
    {
        @foreach (var item in _items)
        {
            <div class="card price-row">
                <strong>@item.ProductName</strong>
                <span class="muted">Comprado @item.TimesBought vez(es)</span>
            </div>
        }
    }

    <p class="muted"><IconInlineLink Href="configuracoes" Icon="@AppIcons.Back" Label="Configurações" /></p>
</PageLayout>

@code {
    private bool _loaded;
    private IReadOnlyList<SmartListItem> _items = [];

    protected override async Task OnInitializedAsync()
    {
        _items = await SmartLists.GetSuggestionsAsync();
        _loaded = true;
    }
}
