@page "/comparar-mercados/{ProductId:guid}"
@inject AccountService Account
@inject MarketComparisonClient Comparison

<PageTitle>Sabor Mercado — Comparar mercados</PageTitle>

<div class="premium-page">
    <PageIcon Icon="@AppIcons.Compare" Title="Comparação entre mercados" />

    @if (!_loaded)
    {
        <p class="muted">Carregando…</p>
    }
    else if (!Account.HasUnlock(PremiumFeatureCodes.MarketComparison))
    {
        <p class="muted">Desbloqueie em <IconInlineLink Href="conta" Icon="@AppIcons.Account" Label="Minha conta" /> (20 créditos).</p>
    }
    else if (_comparison is null)
    {
        <p class="muted">Produto não encontrado no catálogo colaborativo.</p>
    }
    else
    {
        <p class="muted">@_comparison.ProductName</p>
        @if (_comparison.Markets.Count == 0)
        {
            <p class="muted">Sem observações em mercados diferentes.</p>
        }
        else
        {
            @foreach (var market in _comparison.Markets)
            {
                <div class="card price-row">
                    <strong>@market.MarketName</strong>
                    @if (!string.IsNullOrWhiteSpace(market.City))
                    {
                        <span class="muted"> · @market.City</span>
                    }
                    <p>@MoneyFormat.Format(market.Price) <span class="muted">· @market.ObservedOn.ToString("dd/MM/yyyy")</span></p>
                </div>
            }
        }
    }

    <p class="muted"><IconInlineLink Href="catalogo-colaborativo" Icon="@AppIcons.Back" Label="Catálogo colaborativo" /></p>
</div>

@code {
    [Parameter]
    public Guid ProductId { get; set; }

    private bool _loaded;
    private Contracts.SharedCatalog.MarketPriceComparisonResponse? _comparison;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await Account.InitializeAsync();
        if (Account.HasUnlock(PremiumFeatureCodes.MarketComparison))
        {
            try
            {
                _comparison = await Comparison.GetAsync(ProductId);
            }
            catch (CollaborativeCatalogException ex)
            {
                _error = ex.Message;
            }
        }

        _loaded = true;
    }
}
