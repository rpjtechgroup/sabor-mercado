@page "/estatisticas"
@inject PremiumStatsService Stats

<PageTitle>Sabor Mercado — Estatísticas</PageTitle>

<div class="premium-page">
    <PageLayout Icon="@AppIcons.Chart" Title="Estatísticas de gastos">
    @if (!_loaded)
    {
        <p class="muted">Carregando…</p>
    }
    else if (_stats is null || _stats.FinishedTrips == 0)
    {
        <p class="muted">Finalize algumas compras para ver estatísticas.</p>
    }
    else
    {
        <div class="card">
            <p>Compras finalizadas: <strong>@_stats.FinishedTrips</strong></p>
            <p>Média por compra: <strong>@MoneyFormat.Format(_stats.AverageSpend)</strong></p>
            <p>Maior compra: <strong>@MoneyFormat.Format(_stats.HighestSpend)</strong></p>
            <p>Menor compra: <strong>@MoneyFormat.Format(_stats.LowestSpend)</strong></p>
        </div>

        <SectionIcon Icon="@AppIcons.Calendar" Title="Últimos meses" />
        @foreach (var month in _stats.RecentMonths)
        {
            <div class="card price-row">
                <strong>@month.Label</strong>
                <span class="muted">@month.Trips compra(s) · @MoneyFormat.Format(month.TotalSpend)</span>
            </div>
        }
    }

    <p class="muted"><IconInlineLink Href="configuracoes" Icon="@AppIcons.Back" Label="Configurações" /></p>
    </PageLayout>
</div>

@code {
    private bool _loaded;
    private SpendingStats? _stats;

    protected override async Task OnInitializedAsync()
    {
        _stats = await Stats.GetStatsAsync();
        _loaded = true;
    }
}
