
<div class="field">
    <label for="@_inputId">@Label</label>
    @if (_loaded && StoreService.Stores.Count == 0)
    {
        <p class="muted">Nenhum comércio cadastrado.</p>
        <IconLink Href="comercios" Icon="@AppIcons.Store" Label="Cadastrar comércio" CssClass="btn btn-outline btn-block btn-icon icon-link" />
    }
    else
    {
        <select id="@_inputId" class="input" value="@SelectedStoreId" @onchange="OnStoreChangedAsync">
            <option value="@Guid.Empty">@Placeholder</option>
            @foreach (var store in StoreService.Stores)
            {
                <option value="@store.Id">@store.DisplayLabel</option>
            }
        </select>
    }
</div>

@code {
    private static int _idCounter;
    private readonly string _inputId = $"store-picker-{Interlocked.Increment(ref _idCounter)}";
    private bool _loaded;

    [Parameter]
    public string Label { get; set; } = "Comércio *";

    [Parameter]
    public string Placeholder { get; set; } = "Selecione…";

    [Parameter]
    public Guid SelectedStoreId { get; set; }

    [Parameter]
    public EventCallback<Guid> SelectedStoreIdChanged { get; set; }

    [Parameter]
    public bool AutoSelectSingleStore { get; set; } = true;

    [Inject]
    public StoreService StoreService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await StoreService.InitializeAsync();
        await TryAutoSelectSingleStoreAsync();
        _loaded = true;
    }

    private async Task OnStoreChangedAsync(ChangeEventArgs args)
    {
        if (!Guid.TryParse(args.Value?.ToString(), out var storeId))
        {
            storeId = Guid.Empty;
        }

        if (storeId == SelectedStoreId)
        {
            return;
        }

        SelectedStoreId = storeId;
        await SelectedStoreIdChanged.InvokeAsync(storeId);
    }

    private async Task TryAutoSelectSingleStoreAsync()
    {
        if (!AutoSelectSingleStore || SelectedStoreId != Guid.Empty || StoreService.Stores.Count != 1)
        {
            return;
        }

        SelectedStoreId = StoreService.Stores[0].Id;
        await SelectedStoreIdChanged.InvokeAsync(SelectedStoreId);
    }
}
