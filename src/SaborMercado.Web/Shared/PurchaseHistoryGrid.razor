@using SaborMercado.Web.Domain.Shopping

@if (Rows.Count == 0)
{
    <p class="muted">Nenhum item neste período.</p>
}
else
{
    <div class="excel-scroll">
        <table class="excel-table" aria-label="Histórico de compras">
            <thead>
                <tr>
                    @if (ShowDate)
                    {
                        <th scope="col">Data</th>
                    }
                    <th scope="col">Mercado</th>
                    <th scope="col">Produto</th>
                    <th scope="col">Peso/Volume</th>
                    <th scope="col">Valor</th>
                    <th scope="col">Δ</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Rows)
                {
                    <tr>
                        @if (ShowDate)
                        {
                            <td>@row.PurchaseDate.ToString("dd/MM/yyyy")</td>
                        }
                        <td>@(row.MarketName ?? "—")</td>
                        <td><strong>@row.ProductName</strong></td>
                        <td>@(row.VolumeLabel ?? "—")</td>
                        <td class="@TrendClass(row.Trend)">
                            @MoneyFormat.Format(row.UnitPrice)
                            @if (row.DeltaVsPrevious is { } delta && delta != 0m)
                            {
                                <span class="cell-delta">(@FormatDelta(delta))</span>
                            }
                        </td>
                        <td class="@TrendClass(row.Trend)">@FormatDeltaColumn(row.DeltaVsPrevious)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<PurchaseLineRow> Rows { get; set; } = [];

    [Parameter]
    public bool ShowDate { get; set; }

    private static string TrendClass(PriceTrend trend) => trend switch
    {
        PriceTrend.Cheaper => "price-cheaper",
        PriceTrend.MoreExpensive => "price-higher",
        _ => "price-neutral",
    };

    private static string FormatDelta(decimal delta)
    {
        var sign = delta > 0m ? "+" : string.Empty;
        return $"{sign}{MoneyFormat.Format(delta)}";
    }

    private static string FormatDeltaColumn(decimal? delta) =>
        delta is null ? "—" : FormatDelta(delta.Value);
}
