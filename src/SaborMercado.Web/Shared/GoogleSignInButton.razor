@implements IGoogleSignInListener
@implements IAsyncDisposable
@inject IGoogleSignInService GoogleSignIn
@inject IConfiguration Configuration
@inject AccountService Account

<div id="@_elementId" class="google-signin-host btn-block"></div>

@code {
    [Parameter]
    public EventCallback<string> OnError { get; set; }

    private readonly string _elementId = $"google-btn-{Guid.NewGuid():N}";
    private bool _rendered;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_rendered)
        {
            return;
        }

        var clientId = Configuration["GoogleClientId"];
        if (string.IsNullOrWhiteSpace(clientId))
        {
            return;
        }

        _rendered = await GoogleSignIn.RenderButtonAsync(_elementId, clientId, this);
        if (!_rendered)
        {
            await OnError.InvokeAsync("Não foi possível carregar o login com Google.");
        }
    }

    [JSInvokable]
    public async Task OnGoogleCredential(string credential)
    {
        try
        {
            await Account.LoginWithGoogleAsync(credential);
        }
        catch (AccountException ex)
        {
            await OnError.InvokeAsync(ex.Message);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (GoogleSignIn is IAsyncDisposable disposable)
        {
            await disposable.DisposeAsync();
        }
    }
}
