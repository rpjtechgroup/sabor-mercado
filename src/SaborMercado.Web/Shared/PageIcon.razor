<h1 class="page-icon-title" title="@Title" aria-label="@Title">
    <span class="icon-glyph icon-glyph-lg" aria-hidden="true">@Icon</span>
    <span class="icon-label">@Title</span>
</h1>

@code {
    [Parameter]
    public string Icon { get; set; } = AppIcons.Catalog;

    [Parameter]
    public string Title { get; set; } = string.Empty;
}
