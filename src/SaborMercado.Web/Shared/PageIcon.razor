<h1 class="page-icon-title" title="@Title" aria-label="@Title">
    <IconContent Icon="@Icon" Label="@Title" GlyphClass="icon-glyph-lg" />
</h1>

@code {
    [Parameter]
    public string Icon { get; set; } = AppIcons.Catalog;

    [Parameter]
    public string Title { get; set; } = string.Empty;
}
