@using SaborMercado.Web.Domain.Shopping

@if (Rows.Count == 0)
{
    <p class="muted">Sem dados para comparar mercados nos últimos 3 meses.</p>
}
else
{
    <div class="excel-scroll">
        <table class="excel-table" aria-label="Comparador de preços por mercado">
            <thead>
                <tr>
                    <th scope="col">Produto</th>
                    <th scope="col">Peso/Volume</th>
                    @foreach (var market in MarketColumns)
                    {
                        <th scope="col">@market</th>
                    }
                    <th scope="col">Melhor</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Rows)
                {
                    <tr>
                        <td><strong>@row.ProductName</strong></td>
                        <td>@(row.VolumeLabel ?? "—")</td>
                        @foreach (var market in MarketColumns)
                        {
                            var cell = row.Cells.FirstOrDefault(c =>
                                string.Equals(c.MarketName, market, StringComparison.OrdinalIgnoreCase));
                            if (cell is null)
                            {
                                <td class="cell-empty">—</td>
                            }
                            else
                            {
                                var isBest = row.BestPrice == cell.UnitPrice &&
                                             string.Equals(row.BestMarketName, cell.MarketName, StringComparison.OrdinalIgnoreCase);
                                var isHigher = row.BestPrice is { } minPrice && cell.UnitPrice > minPrice;
                                <td class="@CellClass(isBest, isHigher)">@MoneyFormat.Format(cell.UnitPrice)</td>
                            }
                        }
                        <td class="cell-best">
                            @if (row.BestMarketName is not null && row.BestPrice is { } best)
                            {
                                <span>@row.BestMarketName</span>
                                <br />
                                <strong>@MoneyFormat.Format(best)</strong>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<MarketMatrixRow> Rows { get; set; } = [];

    [Parameter]
    public IReadOnlyList<string> MarketColumns { get; set; } = [];

    private static string CellClass(bool isBest, bool isHigher) => isBest
        ? "cell-best"
        : isHigher
            ? "price-higher"
            : "price-neutral";
}
